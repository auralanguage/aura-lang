fn main() -> Int {
    let numbers: [Int] = [1, 2, 3];
    let sum: Int = 0;
    let i: Int = 0;

    while i < 3 {
        sum = sum + i;
        i = i + 1;
    }

    if sum == 3 && numbers[1] == 2 {
        print("flow ok");
    } else {
        print("flow bad");
    }

    {
        let middle: [Int] = numbers[1:3];
        middle[0] = 77;
        print(numbers[1]);
    }

    insert(numbers, 1, 50);
    print(numbers[1]);

    let indexed: Int = 0;
    for index, value in numbers {
        indexed = indexed + index + value;
    }
    print(indexed);

    return indexed;
}
